<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.audiovisualizer.controller.MainController"
            prefHeight="768.0" prefWidth="1024.0"
            onDragOver="#handleDragOver" onDragDropped="#handleDragAndDrop">
    <BorderPane AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <top>
            <VBox fx:id ="topBar" >
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" minHeight="60.0" maxHeight="60.0">
                    <padding><Insets left="20.0" right="20.0" /></padding>
                    <Label text="Audio Visualizer" style="-fx-font-size: 20px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="menuToggleButton" onAction="#handleOpenMenu" style="-fx-background-color: transparent; -fx-cursor: hand;">
                        <graphic><SVGPath fx:id="menuToggleGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" scaleX="1.3" scaleY="1.3" /></graphic>
                    </Button>
                </HBox>
                <Separator style="-fx-background-color: #2A2A2A; -fx-opacity: 0.5;" />
            </VBox>
        </top>
        <center>
            <AnchorPane fx:id="visualizerContainer" minWidth="0" minHeight="0">
                <Region fx:id="backgroundLayer"
                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                <Canvas fx:id="visualizerCanvas" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
            </AnchorPane>
        </center>
        <bottom>
            <VBox fx:id="mainControlPanel">
                <Separator style="-fx-background-color: #2A2A2A; -fx-opacity: 0.5;" />
                <VBox spacing="10.0">
                    <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
                    <VBox spacing="6.0">
                        <Label fx:id="currentTrackLabel" text="Brak utworu" style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label fx:id="timeLabel" text="00:00 / 00:00" style="-fx-text-fill: #888888; -fx-font-size: 13px;" />
                        <Label fx:id="timePreviewLabel" visible="false" managed="false"
                        text="00:00"
                        style="-fx-text-fill: #4DA6FF; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Slider fx:id="timeSlider" maxWidth="Infinity" />
                    </VBox>
                    <HBox alignment="CENTER_LEFT">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Button fx:id="skipPrevButton" onAction="#handleSkipBackward" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                <graphic><SVGPath fx:id="skipPrevGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" scaleX="1.2" scaleY="1.2" /></graphic>
                            </Button>
                            <StackPane minWidth="40" minHeight="40">
                                <Circle radius="18.0" fill="#192C57" stroke="#192C57" strokeWidth="2.0" mouseTransparent="true" />
                                <Button fx:id="playPauseButton" onAction="#handlePlayPause" minWidth="40" maxWidth="40" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                    <graphic><SVGPath fx:id="playPauseGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" scaleX="1.2" scaleY="1.2" /></graphic>
                                </Button>
                            </StackPane>
                            <Button fx:id="stopButton" onAction="#handleStop" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                <graphic><SVGPath fx:id="stopGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" scaleX="1.1" scaleY="1.1" /></graphic>
                            </Button>
                            <Button fx:id="skipNextButton" onAction="#handleSkipForward" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                <graphic><SVGPath fx:id="skipNextGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" scaleX="1.2" scaleY="1.2" /></graphic>
                            </Button>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT" spacing="2.0">
                            <SVGPath fx:id="soundHighGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" scaleX="1.1" scaleY="1.1" mouseTransparent="true" />
                            <Slider fx:id="volumeSlider" max="1.0" value="0.5" prefWidth="100.0" minWidth="100.0" maxWidth="100.0" />
                            <Label fx:id="volumeLabel" text="50%" style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px;" prefWidth="40.0" />
                            <Button fx:id="fullScreenButton" onAction="#handleToggleFullScreen" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                <graphic><SVGPath fx:id="maximizeGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" scaleX="1.2" scaleY="1.2" /></graphic>
                            </Button>
                        </HBox>
                    </HBox>
                </VBox>
            </VBox>
        </bottom>
    </BorderPane>
    <AnchorPane fx:id="sideMenuContainer" visible="false" managed="false"
                AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.rightAnchor="0.0"
                prefWidth="300.0" minWidth="300.0" maxWidth="300.0">
        <Separator orientation="VERTICAL"
                   style="-fx-background-color: #2A2A2A; -fx-opacity: 0.5;"
                   AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" />
        <VBox fx:id="playlistMenuPane" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="1.0" AnchorPane.rightAnchor="0.0">
            <VBox style="-fx-background-color: transparent;">
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" minHeight="60.0">
                    <padding><Insets left="20.0" right="10.0" /></padding>
                    <Label text="Playlista" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="2.0">
                        <Button fx:id="settingsToggleButton" onAction="#handleOpenSettings" style="-fx-background-color: transparent; -fx-cursor: hand;">
                            <tooltip><Tooltip text="Ustawienia"/></tooltip>
                            <graphic><SVGPath fx:id="playlistSettings" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" scaleX="0.9" scaleY="0.9" /></graphic>
                        </Button>
                        <Button fx:id="menuToggleButton2" onAction="#handleOpenMenu" style="-fx-background-color: transparent; -fx-cursor: hand;">
                            <tooltip><Tooltip text="Zamknij"/></tooltip>
                            <graphic><SVGPath fx:id="menuToggleGraphic2" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" scaleX="1.2" scaleY="1.2" /></graphic>
                        </Button>
                    </HBox>
                </HBox>
                <Separator style="-fx-background-color: #2A2A2A; -fx-opacity: 0.5;" />
            </VBox>
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="playlistContainer" style="-fx-background-color: transparent;">
                </VBox>
            </ScrollPane>
            <VBox style="-fx-background-color: transparent;" minHeight="122.0" prefHeight="148.0" maxHeight="148.0" >
                <Separator style="-fx-background-color: #2A2A2A; -fx-opacity: 0.5;" />
                <VBox spacing="12.0" alignment="CENTER">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="15.0" /></padding>
                    <HBox alignment="CENTER">
                        <Label fx:id="playlistCounterLabel" text="0 / 0" style="-fx-text-fill: #FFFFFF; -fx-font-size: 15px; -fx-font-weight: bold;" />
                    </HBox>
                    <Button onAction="#handleAddTracks" text="+  Dodaj utwory" maxWidth="Infinity" prefHeight="40.0"
                            style="-fx-background-color: #192C57; -fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" />
                    <Label text="lub przeciągnij pliki na ekran" style="-fx-text-fill: #888888; -fx-font-size: 13px; -fx-font-style: italic; -fx-font-weight: bold;" />
                </VBox>
            </VBox>
        </VBox>
        <VBox fx:id="settingsMenuPane"  visible="false" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="1.0" AnchorPane.rightAnchor="0.0">
            <VBox style="-fx-background-color: transparent;">
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" minHeight="60.0">
                    <padding><Insets left="20.0" right="10.0" /></padding>
                    <Label text="Ustawienia" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="2.0">
                        <Button fx:id="settingsCloseButton" onAction="#handleCloseSettings" style="-fx-background-color: transparent; -fx-cursor: hand;">
                            <tooltip><Tooltip text="Zamknij"/></tooltip>
                            <graphic>
                                <SVGPath fx:id="settingsCloseGraphic" fill="transparent" stroke="#FFFFFF" strokeWidth="2.0" strokeLineCap="ROUND" scaleX="1.2" scaleY="1.2" />
                            </graphic>
                        </Button>
                    </HBox>
                </HBox>
                <Separator style="-fx-background-color: #2A2A2A; -fx-opacity: 0.5;" />
            </VBox>
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                <VBox spacing="8.0">
                    <padding><Insets top="10.0" left="10.0" right="10.0" bottom="10.0"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="Liczba słupków: " style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label fx:id="barsCountValueLabel" text="64" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                    </HBox>
                    <Slider fx:id="barsCountSliderNew" min="16" max="128" value="64" blockIncrement="1" snapToTicks="true">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                    </Slider>
                    <HBox alignment="CENTER">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="16" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="128" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                    </HBox>
                </VBox>
                <VBox spacing="8.0">
                    <padding><Insets top="10.0" left="10.0" right="10.0" bottom="10.0"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="Czułość: " style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label fx:id="sensitivityValueLabel" text="1.0" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                    </HBox>
                    <Slider fx:id="sensitivitySliderNew" min="0.5" max="2.0" value="1.0" blockIncrement="0.1">
                    <padding><Insets left="5.0" right="5.0" /></padding>
                    </Slider>
                    <HBox alignment="CENTER">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="0.5" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="2.0" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                    </HBox>
                </VBox>
                <VBox spacing="8.0">
                    <padding><Insets top="10.0" left="10.0" right="10.0" bottom="10.0"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="Odstęp słupków: " style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label fx:id="gapValueLabel" text="2" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                    </HBox>
                    <Slider fx:id="gapSliderNew" max="10" value="2" blockIncrement="1" majorTickUnit="1" minorTickCount="0"
                            snapToTicks="true">
                    <padding><Insets left="5.0" right="5.0" /></padding>
                    </Slider>
                    <HBox alignment="CENTER">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="0" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="10" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                    </HBox>
                </VBox>
                <VBox spacing="8.0">
                    <padding><Insets top="10.0" left="10.0" right="10.0" bottom="10.0"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="Tryb lustrzany" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ToggleButton fx:id="mirrorToggleNew" styleClass="modern-toggle">
                            <graphic>
                                <Region styleClass="thumb" />
                            </graphic>
                        </ToggleButton>
                    </HBox>
                </VBox>
                <VBox spacing="8.0">
                    <padding><Insets top="10.0" left="10.0" right="10.0" bottom="10.0"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="Liczba kolorów: " style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label fx:id="colorsCountValueLabel" text="5" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                    </HBox>
                    <Slider fx:id="colorsCountSlider" min="1" max="5" value="5"
                            blockIncrement="1" majorTickUnit="1" minorTickCount="0"
                            snapToTicks="true" />
                    <HBox alignment="CENTER">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="1" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="5" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
                    </HBox>
                </VBox>
                <Label text="Kolory gradientu" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;">
                    <padding><Insets top="10.0" left="10.0" right="10.0" bottom="5.0"/></padding>
                </Label>
                <VBox fx:id="colorRowsContainer" spacing="6.0" style="-fx-background-color: transparent;">
                    <padding><Insets left="10.0" right="10.0" bottom="10.0"/></padding>
                </VBox>
                <Separator style="-fx-background-color: #2A2A2A; -fx-opacity: 0.5;" />
                <Label text="Kolory tła" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;">
                    <padding><Insets top="10.0" left="10.0" right="10.0" bottom="5.0"/></padding>
                </Label>
                <VBox fx:id="bgColorRowsContainer" spacing="6.0" style="-fx-background-color: transparent;">
                    <padding><Insets left="10.0" right="10.0" bottom="10.0"/></padding>
                </VBox>
                <Label text="Presety gradientu" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;">
                    <padding><Insets top="5.0" left="10.0" right="10.0" bottom="5.0"/></padding>
                </Label>
                <HBox spacing="8.0" alignment="CENTER_LEFT">
                    <padding><Insets left="10.0" right="10.0" bottom="10.0"/>
                    </padding>
                    <ToggleButton fx:id="presetBtn0" styleClass="preset-btn" prefWidth="50" prefHeight="32" />
                    <ToggleButton fx:id="presetBtn1" styleClass="preset-btn" prefWidth="50" prefHeight="32" />
                    <ToggleButton fx:id="presetBtn2" styleClass="preset-btn" prefWidth="50" prefHeight="32" />
                </HBox>
                <VBox spacing="8.0">
                    <padding><Insets left="10.0" right="10.0" bottom="10.0"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <padding><Insets left="5.0" right="5.0" /></padding>
                        <Label text="Kierunek wertykalny" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ToggleButton fx:id="gradientDirectionToggle" styleClass="modern-toggle">
                            <graphic><Region styleClass="thumb" /></graphic>
                        </ToggleButton>
                    </HBox>
                </VBox>
            </VBox>
            </ScrollPane>
        </VBox>
    </AnchorPane>
</AnchorPane>